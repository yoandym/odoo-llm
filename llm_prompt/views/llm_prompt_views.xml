<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Form View for LLM Prompt -->
    <record id="llm_prompt_view_form" model="ir.ui.view">
        <field name="name">llm.prompt.form</field>
        <field name="model">llm.prompt</field>
        <field name="arch" type="xml">
            <form string="LLM Prompt">
                <header>
                    <button name="auto_detect_arguments" string="Auto-detect Arguments" type="object" class="oe_highlight" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_toggle" options="{'terminology': 'archive'}" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Data Analysis Prompt" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" />
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                        </group>
                        <group>
                            <field name="template_count" readonly="1" />
                            <field name="argument_count" readonly="1" />
                            <field name="usage_count" readonly="1" />
                            <field name="last_used" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the purpose and usage of this prompt..." />
                        </page>
                        <page string="Templates" name="templates">
                            <field name="template_ids" context="{'default_prompt_id': active_id}">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle" />
                                    <field name="role" />
                                    <field name="content" />
                                    <field name="condition" />
                                </tree>
                            </field>


                            <div class="alert alert-muted mt-3" style="font-size: 0.95em;" role="alert">
                                <strong>What is available?</strong>
                                <ul>
                                    <li>
                                        <b>arguments</b>: The full dictionary of arguments.<br/>
                                    <code>arguments["user_role"] == "admin"</code>
                                </li>
                                <li>
                                    <b>Individual argument variables</b>: Each argument is available directly.<br/>
                                <code>user_role == "admin"</code>
                            </li>
                        <li>
                            <b>get_related_record(field_name, key_name=None)</b>: Access fields/keys from the related record.<br/>
                        <code>get_related_record("email") == "user@example.com"</code>
                        <br/>
                        <code>get_related_record("custom_dict", "some_key") == "value"</code>
                    </li>
                </ul>
                <strong>What kind of exceution conditions can you use?</strong>
                <ul>
                    <li>
                        <b>Simple checks:</b>
                        <code>'debug in arguments and arguments["debug"]'</code>,                        <code>'user_role == "admin"'</code>,                        <code>'amount &gt; 1000'</code>
                    </li>
                    <li>
                        <b>Combined logic:</b>
                        <code>'country == "US" and age &gt;= 21'</code>,                        <code>'status in ["approved", "pending"]'</code>
                    </li>
                    <li>
                        <b>Negation:</b>
                        <code>'not is_test'</code>
                    </li>
                    <li>
                        <b>Existence:</b>
                        <code>'optional_field is not None'</code>,                        <code>'some_key in arguments'</code>
                    </li>
                    <li>
                        <b>String operations:</b>
                        <code>'email.endswith("@example.com")'</code>
                    </li>
                    <li>
                        <b>Math:</b>
                        <code>'score / max_score &gt; 0.8'</code>
                    </li>
                </ul>
                <strong>Amazing things you can achieve</strong>
                <ul>
                    <li>
                        <b>Dynamic Prompt Flows:</b> Show or hide parts of the prompt based on user input, context, or previous answers.<br/>
                    <i>Example:</i> Only include a "manager instructions" message if <code>user_role == "manager"</code>.
                </li>
                <li>
                    <b>Personalization:</b> Tailor prompts for different user types, languages, or business rules.<br/>
                <i>Example:</i>
                <code>'language == "es"'</code> to show a Spanish template.
            </li>
            <li>
                <b>Conditional Instructions:</b> Add extra instructions for high-value transactions.<br/>
            <i>Example:</i>
            <code>'amount &gt; 10000'</code> → Only include a compliance warning for large amounts.
        </li>
        <li>
            <b>Feature Flags:</b> Enable/disable prompt sections based on feature toggles or debug flags.</li>
        <li>
            <b>Multi-step Workflows:</b> Build complex, branching prompt flows where each step is conditionally included.</li>
    </ul>
</div>

</page>
<page string="Arguments" name="arguments">
<div class="alert alert-warning" role="alert" invisible="not undefined_arguments">
    <strong
                >Warning:</strong> The following arguments are used in templates but not defined in the schema:
    <field name="undefined_arguments" readonly="1" class="oe_inline" />
</div>
<group>
    <field name="arguments_json" widget="json_editor" placeholder="{
  'system_prompt': {
    'type': 'string',
    'description': 'The system instructions for the LLM',
    'required': true,
    'default': 'You are a helpful assistant.'
  },
  'user_input': {
    'type': 'string',
    'description': 'The user input to process',
    'required': true
  }
}" />
    <field name="input_schema_json" readonly="1" widget="json_editor" />
</group>
<div class="alert alert-info" role="alert">
    <p>
        <strong>Arguments Schema Format:</strong>
    </p>
    <p
                >Define arguments as a JSON object where each key is the argument name and the value is its schema.</p>
    <p>Each argument schema can include:</p>
    <ul>
        <li>
            <strong
                    >type</strong>: string, number, boolean, etc.</li>
        <li>
            <strong
                    >description</strong>: Human-readable description</li>
        <li>
            <strong
                    >required</strong>: Whether the argument is required (boolean)</li>
        <li>
            <strong
                    >default</strong>: Default value if not provided</li>
        <li>
            <strong
                    >examples</strong>: Array of example values</li>
    </ul>
    <p>Referenced in templates using <strong
                  >{{argument_name}}</strong> placeholders.</p>
</div>
</page>
<page string="Testing" name="testing">
<group>
    <field name="example_args" widget="json_editor" />
</group>
<div class="alert alert-info" role="alert">
    <p
                >Enter example arguments in JSON format to test this prompt.</p>
</div>
<button name="action_test_prompt" string="Test Prompt" type="object" class="oe_highlight" />
</page>
<page string="Providers" name="providers">
<field name="provider_ids" widget="many2many_tags" />
<field name="publisher_ids" widget="many2many_tags" />
</page>
</notebook>
</sheet>
<div class="oe_chatter">
<field name="message_follower_ids" />
<field name="activity_ids" />
<field name="message_ids" />
</div>
</form>
</field>
</record>

<!-- Tree View for LLM Prompt -->
<record id="llm_prompt_view_tree" model="ir.ui.view">
<field name="name">llm.prompt.tree</field>
<field name="model">llm.prompt</field>
<field name="arch" type="xml">
<tree>
<field name="name" />
<field name="category_id" />
<field name="tag_ids" widget="many2many_tags" />
<field name="template_count" />
<field name="argument_count" />
<field name="usage_count" />
<field name="last_used" />
<field name="active" invisible="1" />
</tree>
</field>
</record>

<!-- Search View for LLM Prompt -->
<record id="llm_prompt_view_search" model="ir.ui.view">
<field name="name">llm.prompt.search</field>
<field name="model">llm.prompt</field>
<field name="arch" type="xml">
<search string="Search Prompts">
<field name="name" />
<field name="description" />
<field name="category_id" />
<field name="tag_ids" />
<filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
<group expand="0" string="Group By">
<filter string="Category" name="group_by_category" domain="[]" context="{'group_by': 'category_id'}" />
<filter string="Last Used" name="group_by_last_used" domain="[]" context="{'group_by': 'last_used'}" />
</group>
</search>
</field>
</record>
<!-- Prompts Menu -->
<record id="llm_prompt_action" model="ir.actions.act_window">
<field name="name">Prompts</field>
<field name="res_model">llm.prompt</field>
<field name="view_mode">tree,form</field>
<field name="help" type="html">
<p class="o_view_nocontent_smiling_face">
                Create your first prompt template
</p>
<p>
                Prompt templates help you create reusable messages for LLM interactions.
</p>
</field>
</record>

</odoo>
