<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Model Form View -->
    <record id="llm_model_view_form" model="ir.ui.view">
        <field name="name">llm.model.view.form</field>
        <field name="model">llm.model</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_fetch_this_model_wizard" string="Fetch This Model Update" type="object" class="oe_highlight" invisible="id == False" help="Fetch the latest information for this specific model from the provider." />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_toggle" options="{'terminology': 'archive'}" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Model Name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="provider_id" />
                            <field name="publisher_id" />
                            <field name="model_use" />
                            <field name="default" />
                        </group>
                        <group>
                            <!-- Basic info only, advanced fields moved to Advanced tab -->
                        </group>
                    </group>
                    <notebook>
                        <page string="Context &amp; Memory" name="context_memory">
                            <div class="alert alert-info mb-4" role="alert">
                                <h5>
                                    <i class="fa fa-memory mr-2"></i>Context &amp; Memory Settings</h5>
                                <p class="mb-0">These parameters control how much text the model can process and remember during conversations.</p>
                            </div>

                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="card">
                                        <div class="card-header">
                                            <h6 class="mb-0">
                                                <i class="fa fa-cube mr-2"></i>Token Limits</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="form-group row mb-2">
                                                <div class="col-sm-4">
                                                    <span class="o_form_label">Context Window</span>
                                                </div>
                                                <div class="col-sm-8">
                                                    <div class="input-group">
                                                        <field name="context_window" class="form-control" />
                                                        <div class="input-group-append">
                                                            <span class="input-group-text">tokens</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row mb-5">
                                                <div class="col-sm-12">
                                                    <small class="text-muted">
                                                        <strong>What it does:</strong> Maximum tokens the model can process in one request (input + output)<br/>
                                                    <strong>Impact:</strong> Higher values allow longer conversations but use more memory<br/>
                                                <strong>Typical range:</strong> 4,096 - 32,768 tokens (~3,000 - 24,000 words)
                                            </small>
                                        </div>
                                    </div>

                                    <div class="form-group row mb-2">
                                        <div class="col-sm-4">
                                            <span class="o_form_label">Max Response</span>
                                        </div>
                                        <div class="col-sm-8">
                                            <div class="input-group">
                                                <field name="max_tokens" class="form-control" />
                                                <div class="input-group-append">
                                                    <span class="input-group-text">tokens</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-sm-12">
                                            <small class="text-muted">
                                                <strong>What it does:</strong> Maximum tokens in the model's response<br/>
                                            <strong>Impact:</strong> Controls response length - lower values = shorter responses<br/>
                                        <strong>Typical range:</strong> 512 - 4,096 tokens (~400 - 3,000 words)
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <i class="fa fa-clock-o mr-2"></i>Performance</h6>
                        </div>
                        <div class="card-body">
                            <div class="form-group row mb-2">
                                <div class="col-sm-4">
                                    <span class="o_form_label">Timeout</span>
                                </div>
                                <div class="col-sm-8">
                                    <div class="input-group">
                                        <field name="request_timeout" class="form-control" />
                                        <div class="input-group-append">
                                            <span class="input-group-text">seconds</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-sm-12">
                                    <small class="text-muted">
                                        <strong>What it does:</strong> Maximum time to wait for a response<br/>
                                    <strong>Impact:</strong> Longer timeouts allow complex requests but may delay error detection<br/>
                                <strong>Typical range:</strong> 30 - 300 seconds
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</page>

<page string="Generation Parameters" name="generation_params">
    <div class="alert alert-info mb-4" role="alert">
        <h5>
            <i class="fa fa-magic mr-2"></i>Generation Parameters</h5>
        <p class="mb-0">These parameters control the creativity, consistency, and style of the model's responses.</p>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fa fa-lightbulb-o mr-2"></i>Creativity &amp; Randomness</h6>
                </div>
                <div class="card-body">
                    <div class="form-group row mb-3">
                        <div class="col-sm-12">
                            <span class="o_form_label fw-bold">Temperature</span>
                            <field name="temperature" />
                        </div>
                    </div>
                    <div class="form-group row mb-5">
                        <div class="col-sm-12">
                            <small class="text-muted">
                                <strong>Controls:</strong> Response creativity and randomness<br/>
                            <span class="badge badge-primary">0.1-0.3</span> Very consistent, factual responses<br/>
                        <span class="badge badge-success">0.5-0.7</span> Balanced creativity and consistency<br/>
                    <span class="badge badge-warning">0.9-1.3</span> More creative and varied responses
                </small>
            </div>
        </div>
        <div class="form-group row mb-3">
            <div class="col-sm-12">
                <span class="o_form_label fw-bold">Top-P</span>
                <field name="top_p" />
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-12">
                <small class="text-muted">
                    <strong>Controls:</strong> Word choice diversity (nucleus sampling)<br/>
                <span class="badge badge-primary">0.1-0.5</span> Conservative word selection<br/>
            <span class="badge badge-success">0.6-0.9</span> Balanced vocabulary diversity<br/>
        <span class="badge badge-warning">0.95-1.0</span> Full vocabulary access
    </small>
</div>
</div>
</div>
</div>
</div>

<div class="col-lg-6">
<div class="card">
<div class="card-header">
<h6 class="mb-0">
<i class="fa fa-filter mr-2"></i>Word Selection &amp; Repetition</h6>
</div>
<div class="card-body">
<div class="form-group row mb-3">
<div class="col-sm-12">
    <span class="o_form_label fw-bold">Top-K</span>
    <field name="top_k" />
</div>
</div>
<div class="form-group row mb-5">
<div class="col-sm-12">
    <small class="text-muted">
        <strong>Controls:</strong> Limits word selection to top K candidates<br/>
    <span class="badge badge-primary">10-40</span> Focused, coherent responses<br/>
<span class="badge badge-success">50-100</span> Balanced word variety<br/>
<span class="badge badge-warning">200+</span> Maximum vocabulary diversity
</small>
</div>
</div>
<div class="form-group row mb-3">
<div class="col-sm-12">
<span class="o_form_label fw-bold">Repeat Penalty</span>
<field name="repeat_penalty" />
</div>
</div>
<div class="form-group row">
<div class="col-sm-12">
<small class="text-muted">
<strong>Controls:</strong> Reduction of repetitive text<br/>
<span class="badge badge-secondary">1.0</span> No penalty (may repeat)<br/>
<span class="badge badge-info">1.05-1.15</span> Light penalty (natural flow)<br/>
<span class="badge badge-primary">1.2-1.3</span> Strong penalty (avoids repetition)
</small>
</div>
</div>
</div>
</div>
</div>
</div>
</page>

<page string="Advanced Configuration" name="advanced_config">
<div class="alert alert-warning mb-4" role="alert">
<h5>
<i class="fa fa-cogs mr-2"></i>Advanced Configuration</h5>
<p class="mb-0">These settings are for advanced users and debugging. Modify with caution.</p>
</div>

<div class="row">
<div class="col-lg-6">
<div class="card">
<div class="card-header">
<h6 class="mb-0">
<i class="fa fa-info-circle mr-2"></i>Model Information</h6>
</div>
<div class="card-body">
<div class="form-group mb-5">
<span class="o_form_label">Model Details</span>
<field name="details_str" readonly="1" widget="ace" />
<small class="text-muted">Technical model information from the provider</small>
</div>

<div class="form-group">
<span class="o_form_label">Model Metadata</span>
<field name="model_info_str" readonly="1" widget="ace" />
<small class="text-muted">Additional metadata and capabilities</small>
</div>
</div>
</div>
</div>

<div class="col-lg-6">
<div class="card">
<div class="card-header">
<h6 class="mb-0">
<i class="fa fa-code mr-2"></i>Custom Parameters</h6>
</div>
<div class="card-body">
<div class="form-group mb-5">
<span class="o_form_label">Legacy Parameters (JSON)</span>
<field name="parameters" widget="ace" style="height: 200px;" />
<small class="text-muted">
<strong>Purpose:</strong> Custom/experimental parameters in JSON format<br/>
<strong>Override behavior:</strong> Values here will override structured parameters above<br/>
<strong>Use case:</strong> Only if you need parameters not available in the UI
</small>
</div>

<div class="form-group">
<span class="o_form_label">Prompt Template</span>
<field name="template" widget="ace" style="height: 200px;" />
<small class="text-muted">
<strong>Purpose:</strong> Model-specific prompt template (if supported by provider)<br/>
<strong>Format:</strong> Use provider-specific template syntax
</small>
</div>
</div>
</div>
</div>
</div>
</page>
</notebook>
</sheet>
<div class="oe_chatter">
<field name="message_follower_ids" />
<field name="message_ids" />
</div>
</form>
</field>
</record>

<!-- Model Tree View -->
<record id="llm_model_view_tree" model="ir.ui.view">
<field name="name">llm.model.view.tree</field>
<field name="model">llm.model</field>
<field name="arch" type="xml">
<tree>
<field name="name" />
<field name="provider_id" />
<field name="model_use" />
<field name="default" />
<field name="active" column_invisible="1" />
</tree>
</field>
</record>

<!-- Model Search View -->
<record id="llm_model_view_search" model="ir.ui.view">
<field name="name">llm.model.view.search</field>
<field name="model">llm.model</field>
<field name="arch" type="xml">
<search>
<field name="name" />
<field name="provider_id" />
<field name="model_use" />
<separator />
<filter string="Default Models" name="default" domain="[('default', '=', True)]" />
<filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
<group expand="0" string="Group By">
<filter string="Provider" name="group_by_provider" context="{'group_by': 'provider_id'}" />
<filter string="Usage" name="group_by_use" context="{'group_by': 'model_use'}" />
</group>
</search>
</field>
</record>

<!-- Model Action -->
<record id="llm_model_action" model="ir.actions.act_window">
<field name="name">LLM Models</field>
<field name="res_model">llm.model</field>
<field name="view_mode">tree,form</field>
<field name="context">{'active_test': False}</field>
<field name="help" type="html">
<p class="o_view_nocontent_smiling_face">
                No models found!
</p>
<p>
                Models will be automatically created when you configure a provider.
</p>
</field>
</record>
</odoo>
