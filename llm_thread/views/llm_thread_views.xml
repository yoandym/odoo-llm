<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Thread Form View: Inherit and add LLM info in a new notebook page -->
    <record id="llm_thread_view_form" model="ir.ui.view">
        <field name="name">llm.thread.view.form</field>
        <field name="model">discuss.channel</field>
        <field name="inherit_id" ref="mail.discuss_channel_view_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="LLM" name="llm">
                    <group>
                        <group>
                            <field name="provider_id" />
                            <field name="model_id" />
                            <field
                                name="tool_ids"
                                widget="many2many_tags"
                                options="{'no_create': True}"
                            />
                        </group>
                        <group>
                            <field name="model" readonly="1" />
                            <field name="res_id" readonly="1" />
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Thread Tree View: Inherit and replace tree -->
    <record id="llm_thread_view_tree" model="ir.ui.view">
        <field name="name">llm.thread.view.tree</field>
        <field name="model">discuss.channel</field>
        <field name="inherit_id" ref="mail.discuss_channel_view_tree"/>
        <field name="arch" type="xml">
            <tree position="replace">
                <tree>
                    <field name="name" />
                    <field name="create_uid" />
                    <field name="provider_id" optional="hide"/>
                    <field name="model_id" />
                    <field name="tool_ids" widget="many2many_tags" options="{'no_create': True}" />
                    <field name="write_date" />
                </tree>
            </tree>
        </field>
    </record>

    <!-- Thread Search View (no inherit needed) -->
    <record id="llm_thread_view_search" model="ir.ui.view">
        <field name="name">llm.thread.view.search</field>
        <field name="model">discuss.channel</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="create_uid" />
                <field name="provider_id" />
                <field name="model_id" />
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="llm_thread_action" model="ir.actions.act_window">
        <field name="name">Chat Threads</field>
        <field name="res_model">discuss.channel</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_my_threads': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first chat thread!
            </p>
            <p>
                Start a conversation with any of your configured LLM providers.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <!-- Chat Client Action -->
    <record id="action_llm_chat" model="ir.actions.client">
        <field name="name">Chat</field>
        <field name="tag">llm_thread.chat_client_action</field>
        <field name="params" eval="&quot;{}&quot;" />
    </record>

</odoo>
