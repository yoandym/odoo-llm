<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="llm_thread_rule_personal" model="ir.rule">
        <field name="name">Personal LLM Chat Channels</field>
        <field name="model_id" ref="mail.model_discuss_channel" />
        <field name="domain_force">[('create_uid', '=', user.id), ('provider_id', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
    </record>

    <record id="llm_thread_rule_manager" model="ir.rule">
        <field name="name">All LLM Chat Channels</field>
        <field name="model_id" ref="mail.model_discuss_channel" />
        <field name="domain_force">[('provider_id', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('llm.group_llm_manager'))]" />
    </record>
</odoo>
