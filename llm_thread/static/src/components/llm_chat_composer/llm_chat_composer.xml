<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- LLMChatComposer Template -->
    <t t-name="llm_thread.LLMChatComposer" owl="1">
        <div t-att-class="containerClass">
            <div class="o_LLMChatComposer_container d-flex align-items-end gap-2 mx-auto p-3" style="max-width: 1200px;">

                <!-- Text Input -->
                <div class="o_LLMChatComposer_inputWrapper flex-grow-1">
                    <LLMChatComposerTextInput value="state.textContent" placeholder="placeholder" disabled="state.isDisabled" onValueChange.bind="onTextContentChange" onKeydown.bind="onKeydown" className="'o_LLMChatComposer_input'" onRef.bind="onTextInputRef" />
                </div>

                <!-- Action Buttons -->
                <div class="o_LLMChatComposer_actions d-flex gap-2">
                    <!-- Send Button -->
                    <t t-if="!state.isStreaming">
                        <button class="o_LLMChatComposer_sendButton btn btn-primary" t-att-disabled="isSendDisabled" t-att-title="_t('Send message (Enter)')" t-on-click="onClickSend">
                            <i class="fa fa-paper-plane-o" />
                        </button>
                    </t>

                    <!-- Stop Button -->
                    <t t-else="">
                        <button class="o_LLMChatComposer_stopButton btn btn-danger" t-att-title="_t('Stop generating')" t-on-click="onClickStop">
                            <i class="fa fa-stop" />
                        </button>
                    </t>
                </div>
            </div>

            <!-- Optional: Streaming indicator -->
            <t t-if="state.isStreaming">
                <div class="o_LLMChatComposer_streamingIndicator text-center py-2">
                    <small class="text-muted">
                        <i class="fa fa-circle-o-notch fa-spin me-1" />
                        <span>AI is generating response...</span>
                    </small>
                </div>
            </t>
        </div>
    </t>


</templates>