<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

  <!-- LLMChatMessageList Template -->
  <t t-name="llm_thread.LLMChatMessageList" owl="1">
    <div t-att-class="containerClass">
      <!-- Load More Indicator -->
      <t t-if="props.hasMore">
        <div class="text-center py-3">
          <t t-if="props.isLoading">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
          </t>
          <t t-else="">
            <small class="text-muted">Scroll up to load more messages</small>
          </t>
        </div>
      </t>

      <!-- Grouped Messages -->
      <t t-foreach="groupedMessages" t-as="group" t-key="group.date">
        <!-- Date Separator -->
        <div class="o_LLMChatMessageList_dateSeparator text-center my-3">
          <span class="badge bg-light text-muted px-3 py-2">
            <t t-esc="group.displayDate" />
          </span>
        </div>

        <!-- Messages in Group -->
        <t t-foreach="group.messages" t-as="message" t-key="message.id">
          <div t-att-class="getMessageClass(message)" t-on-mouseenter="onMessageHover.bind(this, message.id)" t-on-mouseleave="onMessageLeave">
            <LLMMessage message="message" isStreaming="isMessageStreaming(message)" />
          </div>
        </t>
      </t>

      <!-- Empty State -->
      <t t-if="!props.messages.length and !props.isLoading">
        <div class="o_LLMChatMessageList_empty text-center py-5">
          <i class="fa fa-comments-o fa-3x text-muted mb-3 opacity-50" />
          <h5 class="text-muted">No messages yet</h5>
          <p class="text-muted">Start the conversation by typing a message below</p>
        </div>
      </t>
    </div>
  </t>
</templates>