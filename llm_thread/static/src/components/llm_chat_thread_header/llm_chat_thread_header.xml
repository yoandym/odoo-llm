<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMChatThreadHeader" owl="1">
        <div class="o_LLMChatThreadHeader d-flex align-items-center px-3 py-2 border-bottom bg-white">
            <!-- Mobile: Toggle Thread List -->
            <button 
                t-if="isMobile"
                class="btn btn-light btn-sm me-2"
                t-on-click="toggleThreadList"
                title="Toggle thread list"
            >
                <i class="fa fa-bars" />
            </button>

            <!-- Thread Name (Editable on Desktop) -->
            <div class="o_LLMChatThreadHeader_title flex-grow-1 me-3">
                <t t-if="!state.isEditingName or isMobile">
                    <h5 
                        class="mb-0 text-truncate"
                        t-att-class="{ 'cursor-pointer': !isMobile }"
                        t-att-title="props.thread.name"
                        t-on-click="startEditingName.bind(this)"
                    >
                        <t t-esc="props.thread.name" />
                        <i t-if="!isMobile" class="fa fa-pencil ms-1 small opacity-50" />
                    </h5>
                </t>
                <t t-else="">
                    <div class="d-flex align-items-center">
                        <input
                            t-ref="threadNameInput"
                            type="text"
                            class="form-control form-control-sm"
                            t-att-value="state.pendingName"
                            t-att-disabled="state.isSaving"
                            t-on-input="onThreadNameInput"
                            t-on-keydown="onThreadNameKeydown"
                            placeholder="Thread name..."
                        />
                        <button 
                            class="btn btn-sm btn-primary ms-1"
                            t-att-disabled="state.isSaving"
                            t-on-click="saveThreadName"
                            title="Save"
                        >
                            <i class="fa fa-check" />
                        </button>
                        <button 
                            class="btn btn-sm btn-secondary ms-1"
                            t-att-disabled="state.isSaving"
                            t-on-click="cancelEditingName"
                            title="Cancel"
                        >
                            <i class="fa fa-times" />
                        </button>
                    </div>
                </t>
            </div>

            <!-- Desktop: Dropdowns -->
            <div t-if="!isMobile" class="o_LLMChatThreadHeader_controls d-flex align-items-center gap-2">
                <!-- Provider Dropdown -->
                <Dropdown 
                    togglerClass="'btn btn-light btn-sm'"
                    menuClass="'o_LLMChatThreadHeader_dropdown'"
                >
                    <t t-set-slot="toggler">
                        <span class="text-truncate" style="max-width: 150px;">
                            <t t-if="selectedProvider" t-esc="selectedProvider.name" />
                            <t t-else="">Select Provider</t>
                        </span>
                        <i class="fa fa-caret-down ms-1" />
                    </t>
                    
                    <t t-foreach="llmProviders" t-as="provider" t-key="provider.id">
                        <DropdownItem
                            onSelected="() => onSelectProvider(provider)"
                            class="{ 'active': state.selectedProviderId === provider.id }"
                        >
                            <t t-esc="provider.name" />
                        </DropdownItem>
                    </t>
                </Dropdown>

                <!-- Model Dropdown with Search -->
                <div class="dropdown" t-ref="modelDropdown">
                    <button
                        class="btn btn-light btn-sm dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                        data-bs-auto-close="outside"
                        t-att-disabled="!state.selectedProviderId"
                        style="max-width: 200px;"
                    >
                        <span class="text-truncate">
                            <t t-if="selectedModel" t-esc="selectedModel.name" />
                            <t t-else="">Select Model</t>
                        </span>
                    </button>
                    
                    <div class="dropdown-menu p-0" style="min-width: 250px;">
                        <!-- Search Input -->
                        <div class="p-2 border-bottom">
                            <input
                                t-ref="modelSearchInput"
                                type="text"
                                class="form-control form-control-sm"
                                placeholder="Search models..."
                                t-att-value="state.modelSearchQuery"
                                t-on-input="onModelSearchInput"
                                t-on-click="preventDropdownClose"
                            />
                        </div>
                        
                        <!-- Model List -->
                        <div style="max-height: 250px; overflow-y: auto;">
                            <t t-if="filteredModels.length">
                                <t t-foreach="filteredModels" t-as="model" t-key="model.id">
                                    <a
                                        href="#"
                                        class="dropdown-item"
                                        t-att-class="{ 'active': state.selectedModelId === model.id }"
                                        t-on-click.prevent="() => onSelectModel(model)"
                                    >
                                        <t t-esc="model.name" />
                                    </a>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="dropdown-item text-muted">
                                    No models found
                                    <t t-if="state.modelSearchQuery">
                                        for "<t t-esc="state.modelSearchQuery" />"
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Tools Dropdown -->
                <div class="dropdown">
                    <button
                        class="btn btn-light btn-sm dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                        data-bs-auto-close="outside"
                    >
                        Tools
                        <t t-if="selectedToolsCount > 0">
                            <span class="badge bg-secondary ms-1">
                                <t t-esc="selectedToolsCount" />
                            </span>
                        </t>
                    </button>
                    
                    <div class="dropdown-menu p-2" style="min-width: 200px;">
                        <h6 class="dropdown-header px-0">Available Tools</h6>
                        <div style="max-height: 250px; overflow-y: auto;">
                            <t t-if="availableTools.length">
                                <t t-foreach="availableTools" t-as="tool" t-key="tool.id">
                                    <div class="form-check">
                                        <input
                                            type="checkbox"
                                            class="form-check-input"
                                            t-att-id="'tool-' + tool.id"
                                            t-att-checked="isToolSelected(tool.id)"
                                            t-on-change="(ev) => onToggleTool(tool, ev.target.checked)"
                                        />
                                        <label 
                                            class="form-check-label"
                                            t-att-for="'tool-' + tool.id"
                                        >
                                            <t t-esc="tool.name" />
                                        </label>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="text-muted small">No tools available</div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile: Settings Button -->
            <button
                t-if="isMobile"
                class="btn btn-light btn-sm"
                t-on-click="openThreadSettings"
                title="Thread settings"
            >
                <i class="fa fa-cog" />
            </button>
        </div>
    </t>
</templates>