<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMChatThreadHeader" owl="1">
        <div class="o_LLMChatThreadHeader d-flex align-items-center px-3 py-2 border-bottom bg-white">
            <!-- Mobile: Toggle Thread List -->
            <button t-if="isMobile" class="btn btn-light btn-sm me-2" t-on-click="toggleThreadList" title="Toggle thread list">
                <i class="fa fa-bars" />
            </button>

            <!-- Thread Name (Editable on Desktop) -->
            <div class="o_LLMChatThreadHeader_title flex-grow-1 me-3">
                <t t-if="!state.isEditingName or isMobile">
                    <div class="d-flex align-items-center">
                        <h5 class="mb-0 text-truncate cursor-pointer me-2" t-att-title="props.thread.name" t-on-click="startEditingName.bind(this)">
                            <t t-esc="props.thread.name" />
                        </h5>

                        <!-- Thread Actions Menu -->
                        <div t-if="!isMobile" class="o_thread_actions">
                            <Dropdown togglerClass="'btn btn-sm btn-light border-0 shadow-none p-1'" menuClass="'dropdown-menu-start'">
                                <t t-set-slot="toggler">
                                    <i class="fa fa-ellipsis-v text-muted" />
                                </t>

                                <DropdownItem onSelected="startEditingName.bind(this)">
                                    <i class="fa fa-pencil fa-fw me-2 text-primary" />
                                    <span>Rename Thread</span>
                                </DropdownItem>

                                <div class="dropdown-divider" />

                                <DropdownItem onSelected="deleteThread.bind(this)">
                                    <i class="fa fa-trash fa-fw me-2 text-danger" />
                                    <span class="text-danger">Delete Thread</span>
                                </DropdownItem>
                            </Dropdown>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="d-flex align-items-center">
                        <input t-ref="threadNameInput" type="text" class="form-control form-control-sm" t-att-value="state.pendingName" t-att-disabled="state.isSaving" t-on-input="onThreadNameInput" t-on-keydown="onThreadNameKeydown" placeholder="Thread name..." />
                        <button class="btn btn-sm btn-primary ms-1" t-att-disabled="state.isSaving" t-on-click="saveThreadName" title="Save">
                            <i class="fa fa-check" />
                        </button>
                        <button class="btn btn-sm btn-secondary ms-1" t-att-disabled="state.isSaving" t-on-click="cancelEditingName" title="Cancel">
                            <i class="fa fa-times" />
                        </button>
                    </div>
                </t>
            </div>

            <!-- Desktop: Dropdowns -->
            <div t-if="!isMobile" class="o_LLMChatThreadHeader_controls d-flex align-items-center gap-2">
                <!-- Provider Dropdown -->
                <Dropdown id="providerDropdown" togglerClass="'btn btn-light btn-sm'" menuClass="'o_LLMChatThreadHeader_dropdown'">
                    <t t-set-slot="toggler">
                        <span class="text-truncate" style="max-width: 150px;">
                            <t t-if="selectedProvider" t-esc="selectedProvider.name" />
                            <t t-else="">Select Provider</t>
                        </span>
                        <i class="fa fa-caret-down ms-1" />
                    </t>

                    <t t-foreach="llmProviders" t-as="provider" t-key="provider.id">
                        <DropdownItem onSelected="onSelectProvider.bind(this, provider)" class="{ 'active': state.selectedProviderId === provider.id }">
                            <t t-esc="provider.name" />
                        </DropdownItem>
                    </t>
                </Dropdown>

                <!-- Model Dropdown with Search -->
                <Dropdown id="modelDropdown" togglerClass="state.selectedProviderId ? 'btn btn-light btn-sm' : 'btn btn-light btn-sm disabled'" menuClass="'o_LLMChatThreadHeader_dropdown'">
                    <t t-set-slot="toggler">
                        <span class="text-truncate" style="max-width: 200px;">
                            <t t-if="selectedModel" t-esc="selectedModel.name" />
                            <t t-else="">Select Model</t>
                        </span>
                        <i class="fa fa-caret-down ms-1" />
                    </t>

                    <t t-foreach="filteredModels" t-as="model" t-key="model.id">
                        <DropdownItem onSelected="onSelectModel.bind(this, model)" class="{ 'active': state.selectedModelId === model.id }">
                            <t t-esc="model.name" />
                        </DropdownItem>
                    </t>
                </Dropdown>

                <!-- Tools Dropdown -->
                <Dropdown id="toolsDropdown" togglerClass="'btn btn-light btn-sm'" menuClass="'o_LLMChatThreadHeader_dropdown dropdown-menu-end'">
                    <t t-set-slot="toggler">
                        Tools
                        <t t-if="selectedToolsCount > 0">
                            <span class="badge bg-secondary ms-1">
                                <t t-esc="selectedToolsCount" />
                            </span>
                        </t>
                        <i class="fa fa-caret-down ms-1" />
                    </t>

                    <t t-foreach="availableTools" t-as="tool" t-key="tool.id">
                        <div class="form-check" t-on-click="(ev) => this.onToggleTool(tool, !this.isToolSelected(tool.id), ev)">
                            <input class="form-check-input" type="checkbox" t-att-id="'tool-' + tool.id" t-att-checked="this.isToolSelected(tool.id)" t-on-click.stop="" />
                            <label class="form-check-label d-flex justify-content-between align-items-center" t-att-for="'tool-' + tool.id">
                                <span t-esc="tool.name" />
                                <small t-if="tool.title" class="text-muted ms-2" t-esc="tool.title" />
                            </label>
                        </div>
                    </t>
                </Dropdown>
            </div>

            <!-- Mobile: Settings Button -->
            <button t-if="isMobile" class="btn btn-light btn-sm" t-on-click="openThreadSettings" title="Thread settings">
                <i class="fa fa-cog" />
            </button>
        </div>
    </t>
</templates>