<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
  <t t-name="llm_thread.LLMChatThreadList" owl="1">
    <div class="o_LLMChatThreadList d-flex flex-column flex-grow-1">
      <!-- Empty State -->
      <t t-if="hasNoThreads">
        <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 text-muted p-4">
          <i class="fa fa-comments-o fa-3x mb-3 opacity-50" />
          <span class="fs-6">No conversations yet</span>
          <span class="small opacity-75 mt-1">Click "New Chat" to start</span>
        </div>
      </t>

      <!-- Thread List -->
      <t t-else="">
        <div class="o_LLMChatThreadList_items">
          <t t-foreach="threads" t-as="thread" t-key="thread.id">
            <div class="o_LLMChatSidebar_item d-flex align-items-center px-3 py-2 cursor-pointer" t-att-class="{
                                'o-active': isThreadActive(thread.id),
                                'opacity-50': isThreadLoading(thread.id)
                            }" t-on-click="onThreadClick.bind(this, thread)">
              <!-- Thread Icon -->
              <i class="fa fa-comment-o me-2 opacity-75" />

              <!-- Thread Name -->
              <span class="text-truncate flex-grow-1" t-esc="thread.name" />

              <!-- Loading Indicator -->
              <t t-if="isThreadLoading(thread.id)">
                <i class="fa fa-spinner fa-spin ms-2 opacity-50" />
              </t>
            </div>
          </t>
        </div>
      </t>
    </div>
  </t>
</templates>
