<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- LLMChatComposerTextInput Template -->
    <t t-name="llm_thread.LLMChatComposerTextInput" owl="1">
        <div class="o_LLMChatComposerTextInput_container position-relative">
            <textarea t-ref="textarea" t-att-class="containerClass" t-att-value="props.value" t-att-placeholder="props.placeholder" t-att-disabled="props.disabled" t-on-input="onInput" t-on-keydown="onKeydown" t-on-focus="onFocus" t-on-blur="onBlur" rows="1" style="min-height: 40px; resize: none;" />

            <!-- Optional: Character counter or other overlay elements -->
            <t t-if="props.value.length > 0">
                <div class="o_LLMChatComposerTextInput_overlay position-absolute bottom-0 end-0 p-1">
                    <small class="text-muted" style="font-size: 0.75rem;">
                        <t t-esc="props.value.length" />
 chars
                    </small>
                </div>
            </t>
        </div>
    </t>
</templates>