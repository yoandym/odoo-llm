<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMChatSidebar" owl="1">
        <!-- Mobile Backdrop -->
        <t t-if="isMobile">
            <div class="o_LLMChatSidebar_backdrop" t-att-class="{ 'o-visible': isVisible }" t-on-click="onBackdropClick" />
        </t>

        <!-- Sidebar Container -->
        <div class="o_LLMChatSidebar d-flex flex-column overflow-auto flex-shrink-0 h-100 border-end bg-view" t-att-class="{
                'o-mobile': isMobile,
                'o-visible': isVisible
            }">
            <!-- New Chat Button -->
            <div class="p-2">
                <button class="btn btn-light w-100 text-start" t-att-disabled="state.isCreatingThread" t-on-click="onClickNewChat">
                    <t t-if="state.isCreatingThread">
                        <i class="fa fa-spinner fa-spin me-2" />
                        <span>Creating...</span>
                    </t>
                    <t t-else="">
                        <i class="fa fa-plus me-2" />
                        <span>New Chat</span>
                    </t>
                </button>
            </div>

            <!-- Thread List -->
            <div class="flex-grow-1 overflow-auto">
                <!-- Always render thread list -->
                <LLMChatThreadList />
            </div>
        </div>
    </t>
</templates>