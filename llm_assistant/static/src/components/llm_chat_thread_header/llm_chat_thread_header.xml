<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- Extend the base LLMChatThreadHeader template -->
    <t t-inherit="llm_thread.LLMChatThreadHeader" t-inherit-mode="extension">
        <!-- Add the Assistant dropdown before the Provider dropdown -->
        <xpath expr="//Dropdown[@id='providerDropdown']" position="before">
            <!-- LLM Assistant Dropdown (NEW) -->
            <Dropdown id="assistantDropdown" togglerClass="state.isLoadingAssistants ? 'btn btn-light btn-sm disabled' : 'btn btn-light btn-sm'" menuClass="'o_LLMChatThreadHeader_dropdown'">
                <t t-set-slot="toggler">
                    <span class="text-truncate" style="max-width: 200px;">
                        <!-- Loading spinner -->
                        <i t-if="state.isLoadingAssistants" class="fa fa-spinner fa-spin me-1"/>

                        <!-- Assistant name or placeholder -->
                        <t t-if="selectedAssistant">
                            <t t-esc="selectedAssistant.name"/>
                        </t>
                        <t t-else="">Select Assistant</t>
                    </span>
                    <i class="fa fa-caret-down ms-1" />
                </t>

                <!-- Clear assistant option -->
                <DropdownItem onSelected="() => this.onClearAssistant()" class="{ 'active': !selectedAssistant }">
                    <i class="fa fa-times me-2 text-muted"/>
                    <span>No Assistant</span>
                </DropdownItem>

                <!-- Assistant list -->
                <t t-if="!state.isLoadingAssistants and llmAssistants.length">
                    <t t-foreach="llmAssistants" t-as="assistant" t-key="assistant.id">
                        <DropdownItem onSelected="() => this.onSelectAssistant(assistant)" class="{ 'active': selectedAssistant and selectedAssistant.id === assistant.id }">
                            <!-- Assistant name -->
                            <span class="text-truncate me-2">
                                <t t-esc="assistant.name"/>
                            </span>

                            <!-- Prompt indicator -->
                            <t t-if="assistant.promptId">
                                <i class="fa fa-file-text-o text-muted" t-att-title="assistant.llmPrompt ? assistant.llmPrompt.name : 'Has prompt'"/>
                            </t>
                        </DropdownItem>
                    </t>
                </t>
            </Dropdown>
        </xpath>

        <!-- Hide Provider/Model/Tools dropdowns when assistant is selected -->
        <xpath expr="//Dropdown[@id='providerDropdown']" position="attributes">
            <attribute name="t-if">shouldShowProviderModelTools</attribute>
        </xpath>
        <xpath expr="//Dropdown[@id='modelDropdown']" position="attributes">
            <attribute name="t-if">shouldShowProviderModelTools</attribute>
        </xpath>
        <xpath expr="//Dropdown[@id='toolsDropdown']" position="attributes">
            <attribute name="t-if">shouldShowProviderModelTools</attribute>
        </xpath>

        <!-- Mobile view: Add assistant info after the title -->
        <xpath expr="//div[hasclass('o_LLMChatThreadHeader_title')]" position="inside">
            <t t-if="selectedAssistant and isMobile" groups="base.group_user">
                <div class="text-truncate small text-muted mt-1">
                    <i class="fa fa-robot me-1"/>
                    <span t-esc="selectedAssistant.name"/>
                </div>
            </t>
        </xpath>
    </t>
</templates>