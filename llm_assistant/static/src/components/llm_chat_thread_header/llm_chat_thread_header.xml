<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- Extend the base LLMChatThreadHeader template -->
    <t t-inherit="llm_thread.LLMChatThreadHeader" t-inherit-mode="extension">
        <!-- Add the Assistant dropdown before the Provider dropdown -->
        <xpath expr="//div[@id='providerDropdown']" position="before">
            <!-- LLM Assistant Dropdown (NEW) -->
            <div id="assistantDropdown" class="d-inline-block">
                <Dropdown togglerClass="'btn btn-light btn-sm'" menuClass="'o_LLMChatThreadHeader_dropdown'">
                    <t t-set-slot="toggler">
                        <span class="text-truncate" style="max-width: 200px;">
                            <!-- Display current assistant or placeholder -->
                            <t t-if="selectedAssistant">
                                <t t-esc="selectedAssistant.name"/>
                            </t>
                            <t t-else="">
                                Select Assistant
                            </t>
                        </span>
                        <i class="fa fa-caret-down ms-1" />
                    </t>
                    
                    <!-- Assistant list -->
                    <t t-if="llmAssistants.length">
                        <t t-foreach="llmAssistants" t-as="assistant" t-key="assistant.id">
                            <DropdownItem 
                                onSelected="() => this.onSelectAssistant(assistant)" 
                                class="{'active': state.selectedAssistant.id === assistant.id || (selectedAssistant and selectedAssistant.id === assistant.id)}"
                            >
                                <!-- Assistant name -->
                                <span class="text-truncate me-2">
                                    <t t-esc="assistant.name"/>
                                </span>

                                <!-- Prompt indicator if available -->
                                <t t-if="assistant.promptId">
                                    <i class="fa fa-file-text-o text-muted ms-1" t-att-title="assistant.llmPrompt ? assistant.llmPrompt.name : 'Has prompt'"/>
                                </t>
                            </DropdownItem>
                        </t>
                    </t>
                </Dropdown>
            </div>
        </xpath>

        <!-- Always hide Provider/Model/Tools dropdowns to enforce assistant usage -->
        <xpath expr="//div[@id='providerDropdown']" position="attributes">
            <attribute name="t-if">false</attribute>
        </xpath>
        <xpath expr="//div[@id='modelDropdown']" position="attributes">
            <attribute name="t-if">false</attribute>
        </xpath>
        <xpath expr="//div[@id='toolsDropdown']" position="attributes">
            <attribute name="t-if">false</attribute>
        </xpath>

        <!-- Mobile view: Add assistant info after the title -->
        <xpath expr="//div[hasclass('o_LLMChatThreadHeader_title')]" position="inside">
            <t t-if="selectedAssistant and isMobile" groups="base.group_user">
                <div class="text-truncate small text-muted mt-1">
                    <i class="fa fa-robot me-1"/>
                    <span t-esc="selectedAssistant.name"/>
                </div>
            </t>
        </xpath>
    </t>
</templates>