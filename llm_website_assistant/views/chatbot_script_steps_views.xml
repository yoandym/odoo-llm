<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend chatbot script step form to add LLM step option -->
    <record id="chatbot_script_step_view_form_llm" model="ir.ui.view">
        <field name="name">chatbot.script.step.form.llm</field>
        <field name="model">chatbot.script.step</field>
        <field name="inherit_id" ref="im_livechat.chatbot_script_step_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='step_type']" position="attributes">
                <attribute name="widget">radio</attribute>
            </xpath>

            <xpath expr="//field[@name='message']" position="attributes">
                <attribute name="required">step_type not in ['forward_operator', 'llm_processed_input']</attribute>
            </xpath>
            
            <xpath expr="//field[@name='is_forward_operator_child']" position="after">
                <div class="alert alert-info text-center mb-0" role="alert" invisible="step_type != 'llm_processed_input'">
                    <span>
                    <strong>LLM Processed Input: </strong>This step will use an AI assistant to respond to the visitor's messages.
                    Make sure to configure one on the script (chatbot) settings.
                    </span>
                </div>
            </xpath>
        </field>
    </record>
    
</odoo>
