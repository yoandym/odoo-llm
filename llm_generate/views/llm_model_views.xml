<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Inherit Form View -->
    <record id="llm_model_view_form_inherit_generate" model="ir.ui.view">
        <field name="name">llm.model.form.inherit.generate</field>
        <field name="model">llm.model</field>
        <field name="inherit_id" ref="llm.llm_model_view_form" />
        <field name="arch" type="xml">
            <!-- Add Input/Output Schema notebook after the main group of fields -->
            <xpath expr="//sheet/group[1]" position="after">
                <notebook
          attrs="{'invisible': [('model_use', 'not in', ['image_generation'])]}"
        >
                    <page string="Input Schema" name="input_schema_page">
                        <field name="input_schema" widget="json_editor" />
                    </page>
                    <page string="Output Schema" name="output_schema_page">
                        <field name="output_schema" widget="json_editor" />
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
