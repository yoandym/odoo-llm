<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Security Groups -->
    <record model="ir.module.category" id="module_category_llm_observability">
        <field name="name">LLM Observability</field>
        <field name="description">Manage LLM observability and monitoring</field>
        <field name="sequence">15</field>
    </record>

    <record model="res.groups" id="group_llm_observability_user">
        <field name="name">LLM Observability User</field>
        <field name="category_id" ref="module_category_llm_observability"/>
        <field name="comment">Can view LLM traces and observability data</field>
    </record>

    <record model="res.groups" id="group_llm_observability_manager">
        <field name="name">LLM Observability Manager</field>
        <field name="category_id" ref="module_category_llm_observability"/>
        <field name="implied_ids" eval="[(4, ref('group_llm_observability_user'))]"/>
        <field name="comment">Can manage Phoenix configuration and observability settings</field>
    </record>

    <!-- Record Rules -->

    <record model="ir.rule" id="phoenix_config_manager_rule">
        <field name="name">Phoenix Config: Manager Access</field>
        <field name="model_id" ref="model_phoenix_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_llm_observability_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
